rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    match /users/{userId} {
      // Validate Products under user
      match /products/{productId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(productId);
      }
      
      // Validate Customers under user
      match /customers/{customerId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(customerId);
      }
      
      // Validate Suppliers under user
      match /suppliers/{supplierId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(supplierId);
      }
      
      // Validate Purchase Orders under user
      match /purchase_orders/{orderId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(orderId);
      }
      
      // Validate Sales Records under user
      match /sales_records/{saleId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(saleId);
      }
    }
  }
}
